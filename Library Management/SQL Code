--create tables

CREATE TABLE Books_T 
    (Books_ID      number(3)      not null,
     Title         varchar(100)   not null, 
     Author        varchar(100)   not null, 
     ISBN          varchar(20)    not null, 
     Genre         varchar(50)    not null, 
     Publisher     varchar(100)   not null, 
     Year_Published number(4)     not null, 
    Copies_Available number(10)  not null, 
CONSTRAINT Books_ID_PK PRIMARY KEY (Books_ID));

CREATE TABLE Members_T 
    ( Members_ID  number(3)       not null, 
      Email      varchar(100)     not null, 
      First_Name       varchar(100) not null,
      Last_Name         varchar(100) not null, 
      Membership_Type   varchar(50) not null, 
      Membership_Date   DATE        not null,
      Address           varchar(100)  not null, 
CONSTRAINT Members_ID_PK PRIMARY KEY (Members_ID));

CREATE TABLE Staff_T 
    (Staff_ID    number(3)     not null, 
     First_Name    varchar(100)  not null, 
     Last_Name     varchar(100)  not null, 
     Email        varchar(100)  not null, 
     Staff_Role     varchar(50)  not null,
CONSTRAINT Staff_ID_PK PRIMARY KEY (Staff_ID)); 

CREATE TABLE Loans_T 
    ( Loans_ID     number(3)    not null,
      Members_ID   number(3)       not null,
      Books_ID      number(3)      not null,
      Staff_ID    number(3)     not null, 
      Loan_Date     DATE        not null, 
      Due_Date      DATE        not null, 
      Return_Date   DATE        ,
CONSTRAINT Loans_ID_PK PRIMARY KEY (Loans_ID), 
CONSTRAINT Members_ID_FK FOREIGN KEY(Members_ID) REFERENCES Members_T(Members_ID),
CONSTRAINT Books_ID_FK FOREIGN KEY(Books_ID) REFERENCES Books_T(Books_ID), 
CONSTRAINT Staff_ID_FK FOREIGN KEY(Staff_ID) REFERENCES Staff_T(Staff_ID));

CREATE TABLE Fine_T 
    (Fine_ID    number(3)    not null, 
     Loans_ID    number(3)    not null, 
     Amount     number(6,2)  not null, 
     Fine_Date  date          not null, 
     Paid_Status varchar(10)  not null,
CONSTRAINT Fine_ID_PK PRIMARY KEY(Fine_ID), 
CONSTRAINT Loans_ID_FK FOREIGN KEY(Loans_ID) REFERENCES Loans_T(Loans_ID));

