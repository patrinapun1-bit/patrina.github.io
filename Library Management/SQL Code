--two select statements 


-- What Fiction books does the library have and what are their authors/ISBN numbers?
SELECT Title, Author, ISBN 
FROM Books_T 
WHERE Genre= 'Fiction'; 

-- Who are the librarians on staff and how can they be contacted 
SELECT First_Name, Last_Name, Email 
FROM Staff_T 
WHERE Staff_Role='Librarian'; 

--join queries 

-- Which members borrowed books and have no fine amount charged to them
SELECT First_Name, Last_Name, Title
FROM Members_T 
INNER JOIN Loans_T ON Members_T.Members_ID = Loans_T.Members_ID
INNER JOIN Books_T ON Books_T.Books_ID = Loans_T.Books_ID
INNER JOIN Fine_T ON Fine_T.Loans_ID = Loans_T.Loans_ID
 WHERE Amount= 0.00; 
 
 --Which members currently have unpaid fines and how much do they owe 
 
 SELECT First_Name, Last_Name, Amount 
 FROM Members_T 
INNER JOIN Loans_T ON Members_T.Members_ID = Loans_T.Members_ID
INNER JOIN Fine_T ON Fine_T.Loans_ID = Loans_T.Loans_ID
WHERE Fine_T.Paid_Status = 'Unpaid';
 
 
 -- which staff member processed each loan for which member and what book was borrowed-ordered by date? 
SELECT Members_T.First_Name,Members_T.Last_Name, Staff_T.First_Name, Staff_T.Last_Name, Title, Loan_Date 
FROM Staff_T 
INNER JOIN Loans_T ON Staff_T.Staff_ID = Loans_T.Staff_ID
INNER JOIN Members_T ON Members_T.Members_ID = Loans_T.Members_ID
INNER JOIN Books_T ON Books_T.Books_ID = Loans_T.Books_ID
ORDER BY Loans_T.Loan_Date;

-- what is the full loan history for each member, including when books were due and returned-ordered by date 
SELECT First_Name, Last_Name, Title, Loan_Date, Due_Date, Return_Date
FROM Members_T
INNER JOIN Loans_T ON Members_T.Members_ID = Loans_T.Members_ID
INNER JOIN Books_T ON Books_T.Books_ID = Loans_T.Books_ID
ORDER BY Loans_T.Loan_Date;

--group by 

--how many members belong to each membership type
SELECT Membership_Type, COUNT(Members_ID) AS Total_Members
FROM Members_T
GROUP BY Membership_Type;


-- how many books does the library have in each genre, ranked from most to least 
SELECT Genre, COUNT(Books_ID) AS Total_Books
FROM Books_T
GROUP BY Genre
ORDER BY COUNT(Books_ID) DESC;
